{
  "permissions": {
    "allow": [
      "Bash(bash .claude/scripts/helpers.sh top-level-listing *)",
      "Bash(bash .claude/scripts/helpers.sh check-commands)"
    ]
  },
  "hooks": {
    "SubagentStop": [
      {
        "matcher": "tech-stack|module-map|external-integrations|data-flows|deployment-infra|runtime-process",
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/hooks/log-subagent.sh\"", "shell": "bash" }
        ]
      }
    ]
  }
}
